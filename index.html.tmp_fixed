    <h2 class="section-title" data-ar="ًں‘¤ ط§ظ„ظ…ظ„ظپ ط§ظ„ط´ط®طµظٹ" data-en="ًں‘¤ Profile">ًں‘¤ ط§ظ„ظ…ظ„ظپ ط§ظ„ط´ط®طµظٹ</h2>

    <div class="profile-card">
      <div class="profile-cover" id="profile-cover">
        <button class="upload-btn cover-upload-btn" onclick="triggerCoverUpload()" type="button">
          <span data-ar="ًں–¼ï¸ڈ ط؛ظٹظ‘ط± ط§ظ„ط؛ظ„ط§ظپ" data-en="ًں–¼ï¸ڈ Change Cover">ًں–¼ï¸ڈ ط؛ظٹظ‘ط± ط§ظ„ط؛ظ„ط§ظپ</span>
        </button>
      </div>
      <div class="profile-avatar" id="profile-avatar">🎮</div>
      <button class="upload-btn avatar-upload-btn" onclick="triggerAvatarUpload()" type="button">
        <span data-ar="ًں“· ط£ط¶ظپ طµظˆط±طھظƒ" data-en="ًں“· Add Your Photo">ًں“· ط£ط¶ظپ طµظˆط±طھظƒ</span>
      </button>
      <input type="file" id="avatar-upload-input" accept="image/*" hidden onchange="handleAvatarUpload(event)">
      <input type="file" id="cover-upload-input" accept="image/*" hidden onchange="handleCoverUpload(event)">
      <h3 id="profile-name">ط§ظ„ظ„ط§ط¹ط¨</h3>
      <div class="avatar-selector">
        <span onclick="changeAvatar('🎮')">🎮</span>
        <span onclick="changeAvatar('🦁')">🦁</span>
        <span onclick="changeAvatar('ًںگ‰')">ًںگ‰</span>
        <span onclick="changeAvatar('🦊')">🦊</span>
        <span onclick="changeAvatar('ًں¤–')">ًں¤–</span>
        <span onclick="changeAvatar('ًں‘¾')">ًں‘¾</span>
        <span onclick="changeAvatar('ًںگ؛')">ًںگ؛</span>
        <span onclick="changeAvatar('🦅')">🦅</span>
      </div>
    </div>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon">🏆</div>
        <div class="stat-val" id="stat-wins">0</div>
        <div class="stat-label" data-ar="ظ…ط±ط§طھ ط§ظ„ظپظˆط²" data-en="Wins">ظ…ط±ط§طھ ط§ظ„ظپظˆط²</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">â­گ</div>
        <div class="stat-val" id="stat-score">0</div>
        <div class="stat-label" data-ar="ط£ط¹ظ„ظ‰ ظ†ظ‚ط§ط·" data-en="High Score">ط£ط¹ظ„ظ‰ ظ†ظ‚ط§ط·</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">🎮</div>
        <div class="stat-val" id="stat-games">0</div>
        <div class="stat-label" data-ar="ظ…ط¨ط§ط±ظٹط§طھ" data-en="Games">ظ…ط¨ط§ط±ظٹط§طھ</div>
      </div>
      <div class="stat-card">
        <div class="stat-icon">ًں”¥</div>
        <div class="stat-val" id="stat-streak">0</div>
        <div class="stat-label" data-ar="ط£ط·ظˆظ„ ط³ظ„ط³ظ„ط©" data-en="Best Streak">ط£ط·ظˆظ„ ط³ظ„ط³ظ„ط©</div>
      </div>
    </div>

    <div class="achievements-section">
      <h3 data-ar="🏅 ط§ظ„ط¥ظ†ط¬ط§ط²ط§طھ" data-en="🏅 Achievements">🏅 ط§ظ„ط¥ظ†ط¬ط§ط²ط§طھ</h3>
      <div class="achievements-grid" id="achievements-grid"></div>
    </div>

    <div class="history-section">
      <h3 data-ar="ًں“ٹ ط³ط¬ظ„ ط§ظ„ظ…ط¨ط§ط±ظٹط§طھ" data-en="ًں“ٹ Game History">ًں“ٹ ط³ط¬ظ„ ط§ظ„ظ…ط¨ط§ط±ظٹط§طھ</h3>
      <div class="history-list" id="history-list"></div>
    </div>
  </div>
</div>

<!-- ===== LEADERBOARD ===== -->
<div id="leaderboard-screen" class="screen">
  <div class="leaderboard-container">
    <button class="back-btn" onclick="showMenu()">â†گ <span data-ar="ط±ط¬ظˆط¹" data-en="Back">ط±ط¬ظˆط¹</span></button>
    <h2 class="section-title" data-ar="🏆 ط§ظ„ظ…طھطµط¯ط±ظˆظ†" data-en="🏆 Leaderboard">🏆 ط§ظ„ظ…طھطµط¯ط±ظˆظ†</h2>
    <div class="leaderboard-list" id="leaderboard-list"></div>
  </div>
</div>

<!-- ===== PAUSE MODAL ===== -->
<div id="pause-modal" class="modal hidden">
  <div class="modal-box">
    <h3 data-ar="âڈ¸ ظ…طھظˆظ‚ظپ" data-en="âڈ¸ Paused">âڈ¸ ظ…طھظˆظ‚ظپ</h3>
    <button class="modal-btn btn-resume" onclick="resumeGame()"><span data-ar="ط§ط³طھظ…ط±ط§ط±" data-en="Resume">ط§ط³طھظ…ط±ط§ط±</span></button>
    <button class="modal-btn btn-restart" onclick="restartGame()"><span data-ar="ط¥ط¹ط§ط¯ط©" data-en="Restart">ط¥ط¹ط§ط¯ط©</span></button>
    <button class="modal-btn btn-quit" onclick="showMenu()"><span data-ar="ط®ط±ظˆط¬" data-en="Quit">ط®ط±ظˆط¬</span></button>
  </div>
</div>

<!-- ===== WIN MODAL ===== -->
<div id="win-modal" class="modal hidden">
