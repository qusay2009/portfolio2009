    <p class="win-score" id="win-score-text"></p>
    <div class="win-badges" id="win-badges"></div>
    <button class="modal-btn btn-play" onclick="nextLevel()"><span data-ar="ط§ظ„ظ…ط³طھظˆظ‰ ط§ظ„طھط§ظ„ظٹ â–¶" data-en="Next Level â–¶">ط§ظ„ظ…ط³طھظˆظ‰ ط§ظ„طھط§ظ„ظٹ â–¶</span></button>
    <button class="modal-btn btn-quit" onclick="showMenu()"><span data-ar="القائمة" data-en="Menu">القائمة</span></button>
  </div>
</div>

<!-- ===== GAME OVER MODAL ===== -->
<div id="gameover-modal" class="modal hidden">
  <div class="modal-box gameover-box">
    <h3 data-ar="ًں’¥ ط§ظ†طھظ‡طھ ط§ظ„ظ„ط¹ط¨ط©" data-en="ًں’¥ Game Over">ًں’¥ ط§ظ†طھظ‡طھ ط§ظ„ظ„ط¹ط¨ط©</h3>
    <p class="gameover-score" id="go-score-text"></p>
    <button class="modal-btn btn-restart" onclick="restartGame()"><span data-ar="ط­ط§ظˆظ„ مجدداً" data-en="Try Again">ط­ط§ظˆظ„ مجدداً</span></button>
    <button class="modal-btn btn-quit" onclick="showMenu()"><span data-ar="القائمة" data-en="Menu">القائمة</span></button>
  </div>
</div>

<!-- ===== EDIT NAME MODAL ===== -->
<div id="editname-modal" class="modal hidden">
  <div class="modal-box editname-box">
    <h3 data-ar="✏️ طھط¹ط¯ظٹظ„ ط§ظ„ظ…ظ„ظپ" data-en="✏️ Edit Profile">✏️ طھط¹ط¯ظٹظ„ ط§ظ„ظ…ظ„ظپ</h3>
    <div class="setup-avatars" id="edit-avatars">
      <span class="setup-av" onclick="pickEditAvatar(this,'🎮')">🎮</span>
      <span class="setup-av" onclick="pickEditAvatar(this,'🦁')">🦁</span>
      <span class="setup-av" onclick="pickEditAvatar(this,'ًںگ‰')">ًںگ‰</span>
      <span class="setup-av" onclick="pickEditAvatar(this,'🦊')">🦊</span>
      <span class="setup-av" onclick="pickEditAvatar(this,'ًں¤–')">ًں¤–</span>
      <span class="setup-av" onclick="pickEditAvatar(this,'ًں‘¾')">ًں‘¾</span>
      <span class="setup-av" onclick="pickEditAvatar(this,'ًںگ؛')">ًںگ؛</span>
      <span class="setup-av" onclick="pickEditAvatar(this,'🦅')">🦅</span>
    </div>
    <div class="input-group" style="margin:16px 0">
      <span class="input-icon" id="edit-av-preview">🎮</span>
      <input type="text" id="edit-name-input" maxlength="20"
             placeholder="ط§ط³ظ…ظƒ الجديد…"
             data-ph-ar="ط§ط³ظ…ظƒ الجديد…" data-ph-en="New name…"
             oninput="validateEditName()"
             onkeydown="if(event.key==='Enter')saveEditName()">
    </div>
    <button class="upload-btn modal-upload-btn" type="button" onclick="triggerAvatarUpload()">
      <span data-ar="ًں–¼ï¸ڈ ط§ط®طھط± طµظˆط±ط© ط´ط®طµظٹط© ظ…ظ† ط¬ظ‡ط§ط²ظƒ" data-en="ًں–¼ï¸ڈ Choose a profile image from your device">ًں–¼ï¸ڈ ط§ط®طھط± طµظˆط±ط© ط´ط®طµظٹط© ظ…ظ† ط¬ظ‡ط§ط²ظƒ</span>
    </button>
    <button class="modal-btn btn-resume" id="edit-save-btn" onclick="saveEditName()">
      <span data-ar="ًں’¾ ط­ظپط¸" data-en="ًں’¾ Save">ًں’¾ ط­ظپط¸</span>
    </button>
    <button class="modal-btn btn-quit" onclick="closeEditName()">
      <span data-ar="ط¥ظ„ط؛ط§ط،" data-en="Cancel">ط¥ظ„ط؛ط§ط،</span>
    </button>
  </div>
</div>

<!-- ===== CYBER CHARACTER SELECT MODAL ===== -->
<div id="cyber-char-modal" class="modal hidden">
  <div class="modal-box cyber-modal-box">
    <h3 data-ar="ًں‘¾ ط§ط®طھط± ظ…ط±ظƒط¨طھظƒ" data-en="ًں‘¾ Choose Ship">ًں‘¾ ط§ط®طھط± ظ…ط±ظƒط¨طھظƒ</h3>
    <div class="cyber-ships-grid">
      <!-- Emojis as fallback/extra -->
      <div class="cyber-ship-av selected" onclick="selectCyberShip(this, 'ًںڑ€')">ًںڑ€</div>
      <div class="cyber-ship-av" onclick="selectCyberShip(this, '🛸')">🛸</div>
      
      <!-- Premium New Ships (from sprite sheet) -->
      <div class="cyber-ship-av ship-img-av" onclick="selectCyberShip(this, '', 'image', 0)" style="background-image: url('assets/neon_ships.png'); background-position: 0 0;"></div>
      <div class="cyber-ship-av ship-img-av" onclick="selectCyberShip(this, '', 'image', 1)" style="background-image: url('assets/neon_ships.png'); background-position: 33.3% 0;"></div>
      <div class="cyber-ship-av ship-img-av" onclick="selectCyberShip(this, '', 'image', 2)" style="background-image: url('assets/neon_ships.png'); background-position: 66.6% 0;"></div>
      <div class="cyber-ship-av ship-img-av" onclick="selectCyberShip(this, '', 'image', 3)" style="background-image: url('assets/neon_ships.png'); background-position: 100% 0;"></div>
      <div class="cyber-ship-av ship-img-av" onclick="selectCyberShip(this, '', 'image', 4)" style="background-image: url('assets/neon_ships.png'); background-position: 0 33.3%;"></div>
      <div class="cyber-ship-av ship-img-av" onclick="selectCyberShip(this, '', 'image', 5)" style="background-image: url('assets/neon_ships.png'); background-position: 33.3% 33.3%;"></div>
      <div class="cyber-ship-av ship-img-av" onclick="selectCyberShip(this, '', 'image', 6)" style="background-image: url('assets/neon_ships.png'); background-position: 66.6% 33.3%;"></div>
      <div class="cyber-ship-av ship-img-av" onclick="selectCyberShip(this, '', 'image', 7)" style="background-image: url('assets/neon_ships.png'); background-position: 100% 33.3%;"></div>
    </div>
    
    <div class="cyber-color-picker">
      <h4 data-ar="ط§ط®طھط± ظ„ظˆظ† ط§ظ„ظ„ظٹط²ط± / ط§ظ„طھظˆظ‡ط¬:" data-en="Laser / Glow Color:">ط§ط®طھط± ظ„ظˆظ† ط§ظ„ظ„ظٹط²ط± / ط§ظ„طھظˆظ‡ط¬:</h4>
      <input type="color" id="cyber-color-input" value="#00ffff" onchange="changeCyberColor(this.value)">
    </div>
    
    <button class="modal-btn btn-resume" onclick="closeCyberCharModal()"><span data-ar="طھط£ظƒظٹط¯" data-en="Confirm">طھط£ظƒظٹط¯</span></button>
  </div>
</div>

<!-- ===== CYBER SETTINGS MODAL ===== -->
<div id="cyber-settings-modal" class="modal hidden">
  <div class="modal-box cyber-modal-box">
    <h3 data-ar="âڑ™ï¸ڈ ط¥ط¹ط¯ط§ط¯ط§طھ ط§ظ„ظ…ط¹ط±ظƒط©" data-en="âڑ™ï¸ڈ Battle Settings">âڑ™ï¸ڈ ط¥ط¹ط¯ط§ط¯ط§طھ ط§ظ„ظ…ط¹ط±ظƒط©</h3>
    
    <div class="volume-area" style="margin-top:20px;">
      <span>ًں”ˆ</span>
      <input type="range" id="cyber-volume" class="volume-slider" min="0" max="100" value="60" oninput="setVolume(this.value)">
      <span>ًں”ٹ</span>
    </div>
    
    <button class="modal-btn" onclick="toggleLang()" style="margin-top:20px; background:rgba(255,255,255,0.1);"><span data-ar="طھط؛ظٹظٹط± ط§ظ„ظ„ط؛ط© (EN/AR)" data-en="Change Language (AR/EN)">طھط؛ظٹظٹط± ط§ظ„ظ„ط؛ط© (EN/AR)</span></button>

    <button class="modal-btn btn-resume" onclick="closeCyberSettingsModal()" style="margin-top:20px;"><span data-ar="ط­ظپط¸ ظˆط¥ط؛ظ„ط§ظ‚" data-en="Save & Close">ط­ظپط¸ ظˆط¥ط؛ظ„ط§ظ‚</span></button>
  </div>
</div>

<!-- Toast -->
